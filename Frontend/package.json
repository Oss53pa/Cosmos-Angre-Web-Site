{
  "name": "cosmos-angre-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Application React moderne pour la plateforme Cosmos Angré - Centre Commercial Multi-Tenant",
  "author": "Pratium Tech",
  "license": "Proprietary",
  "scripts": {
    "dev": "vite",
    "build": "npm run sitemap:generate && tsc --noEmit && vite build",
    "build:no-typecheck": "npm run sitemap:generate && vite build",
    "build:fast": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "validate": "npm run type-check && npm run lint && npm run format:check",
    "supabase:types": "echo 'Run: supabase gen types typescript --project-id YOUR_ID > src/types/database.generated.ts'",
    "images:optimize": "node scripts/optimize-images.mjs",
    "images:responsive": "node scripts/optimize-images.mjs --responsive",
    "sitemap:generate": "node scripts/generate-sitemap.mjs",
    "lhci": "lhci autorun"
  },
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.0",
    "@fontsource-variable/cormorant-garamond": "^5.2.6",
    "@fontsource-variable/inter": "^5.2.8",
    "@hookform/resolvers": "^3.3.4",
    "@mui/icons-material": "^5.15.11",
    "@mui/material": "^5.15.11",
    "@reduxjs/toolkit": "^2.2.0",
    "@sentry/react": "^8.55.1",
    "@supabase/supabase-js": "^2.95.3",
    "@types/three": "^0.183.1",
    "chart.js": "^4.4.1",
    "date-fns": "^3.3.1",
    "framer-motion": "^11.0.8",
    "i18next": "^23.10.0",
    "i18next-browser-languagedetector": "^7.2.0",
    "i18next-http-backend": "^2.5.0",
    "lucide-react": "^0.344.0",
    "quill": "^2.0.3",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.51.0",
    "react-i18next": "^14.0.5",
    "react-qr-code": "^2.0.12",
    "react-quill": "^2.0.0",
    "react-redux": "^9.1.0",
    "react-router-dom": "^6.22.0",
    "socket.io-client": "^4.6.1",
    "sonner": "^1.7.4",
    "swiper": "^11.0.7",
    "three": "^0.183.2",
    "yup": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@lhci/cli": "^0.14.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.11.24",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vercel/og": "^0.6.8",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.9",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "vite-plugin-pwa": "^0.19.2",
    "vitest": "^2.1.9",
    "workbox-precaching": "^7.0.0",
    "workbox-routing": "^7.0.0"
  },
  "keywords": [
    "cosmos-angre",
    "centre-commercial",
    "multi-tenant",
    "react",
    "typescript",
    "vite",
    "shopping-mall"
  ]
}
