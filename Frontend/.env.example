# ============================================================
# Cosmos Angré — Variables d'environnement (frontend)
# ============================================================
# Toute variable préfixée VITE_ est exposée au navigateur.
# Ne JAMAIS y mettre un secret serveur (clé service_role, API keys).

# --- Supabase (REQUIS) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Application ---
VITE_APP_NAME=Cosmos Angré
VITE_APP_URL=https://www.cosmos-angre.com
VITE_DEFAULT_LANGUAGE=fr
VITE_SUPPORTED_LANGUAGES=fr,en

# --- Feature flags ---
VITE_ENABLE_AR=true
VITE_ENABLE_BLOG=true
VITE_ENABLE_NEWSLETTER=true
VITE_ENABLE_SOCIAL_MEDIA=true
VITE_ENABLE_PWA=true

# --- Services externes (clés publiques uniquement) ---
VITE_GOOGLE_MAPS_API_KEY=
VITE_STRIPE_PUBLIC_KEY=

# --- Observabilité ---
# Sentry (DSN public côté client, projet "cosmos-angre-web")
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# Plausible Analytics (RGPD-friendly, sans cookies)
VITE_PLAUSIBLE_DOMAIN=cosmos-angre.com
VITE_PLAUSIBLE_API_HOST=https://plausible.io

# --- Environnement ---
VITE_ENV=production

# ============================================================
# Variables backend (Edge Functions Supabase) — NE PAS exposer côté client
# Configurer via supabase secrets set ou dashboard Supabase
# ============================================================
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM=Cosmos Angré <noreply@cosmos-angre.com>
# RESEND_REPLY_TO=contact@cosmos-angre.com
# CONTACT_NOTIFICATION_EMAIL=contact@cosmos-angre.com
# RATE_LIMIT_REDIS_URL=
# SENTRY_DSN_BACKEND=
